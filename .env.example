# Copy this file to .env and fill in real values before deploying.

PORT=3000
NODE_ENV=development

# Where contact-form enquiries should be sent
SHOP_EMAIL=hello@foldclothing.example

# SMTP (optional — leave blank in development; the server will log
# submissions to the console instead of sending real email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Comma-separated allowed origins for the API in production, e.g.
# CORS_ORIGINS=https://foldclothing.com,https://www.foldclothing.com
CORS_ORIGINS=*
